<?xml version="1.0" encoding="utf-8"?>
<!--
    Pre-Android 12 (auto backup) rules.
    Excludes everything: secrets, photos and metadata must never leave the device
    via Google Drive backup.
-->
<full-backup-content>
    <exclude domain="root" />
    <exclude domain="file" />
    <exclude domain="database" />
    <exclude domain="sharedpref" />
    <exclude domain="external" />
</full-backup-content>
